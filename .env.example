# ==============================
# Fonial SIP trunk placeholders
# ==============================
# IMPORTANT: These are used to render Asterisk PJSIP config in Docker.
# Fill them and copy to .env
FONIAL_USER=
FONIAL_PASS=
FONIAL_DOMAIN=example.fonial.de
FONIAL_REGISTRAR=sip.fonial.de
INBOUND_DID=

# Optional (recommended): match inbound trunk SBC IPs (comma-separated)
# This is used to generate a PJSIP identify section so inbound INVITEs/OPTIONS are matched to the trunk endpoint.
# Supports single IPs and CIDR ranges.
# Example (CIDR): FONIAL_MATCH=92.197.176.0/21
# (covers 92.197.176.0 - 92.197.183.255)
FONIAL_MATCH=

# ==============================
# Asterisk ARI (Node control)
# ==============================
ARI_USER=ariuser
ARI_PASS=aripass
ARI_APP=sipws
# When running locally (not in Docker) set ARI_URL to your Asterisk
# Example: http://127.0.0.1:8088/ari
ARI_URL=http://asterisk:8088/ari

# ==============================
# Node settings
# ==============================
WS_PORT=3000
RTP_PORT=5004
RTP_CODEC=ulaw

# Host:port that Asterisk should send RTP to for ARI External Media.
# In Docker Compose, this must be the Node *service name* (not container_name).
EXTERNAL_MEDIA_HOST=sip-client-node:5004

# Demo behavior
SEND_TEST_BEEP=1
ECHO_INBOUND=0

# Optional diagnostics
DUMP_WAV=0
LOG_RTP_EVERY_N=200

# Log when caller speech is detected (simple energy threshold)
LOG_VAD=1
VAD_THRESHOLD_DBFS=-45
VAD_HANGOVER_MS=600

# ==============================
# NAT helpers (Asterisk)
# ==============================
# If Asterisk is behind NAT, set:
# EXTERNAL_ADDRESS=your.public.ip.or.dns
# LOCAL_NET=192.168.0.0/16
EXTERNAL_ADDRESS=
LOCAL_NET=172.16.0.0/12

# RTP port range in container
RTP_START=10000
RTP_END=10100
